{
  "name": "@pr-agent/agent",
  "version": "0.1.0",
  "private": true,
  "description": "Node + TypeScript backend for the pr-review CLI.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "pr-review": "./dist/index.js",
    "pr-agent-agent": "./dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx --test-reporter=spec tests/protocol.test.ts tests/config.test.ts tests/url.test.ts tests/argv.test.ts tests/env.test.ts tests/skills.test.ts",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@cursor/sdk": "^1.0.13",
    "@octokit/rest": "^21.0.2",
    "openai": "^4.68.0",
    "pino": "^9.5.0",
    "smol-toml": "^1.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}

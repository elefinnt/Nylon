{
  "name": "nylon",
  "version": "0.4.1",
  "private": true,
  "description": "Nylon - a CLI that posts AI code reviews onto GitHub pull requests.",
  "license": "MIT",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -F @nylon/agent build",
    "dev": "pnpm -F @nylon/agent dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  }
}
